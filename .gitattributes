# Force LF line endings on files that must stay Unix-style.
# Without this, Windows checkouts (Dan's dev machine) would commit CRLF,
# which breaks shell scripts running inside Linux containers ("bad
# interpreter: /usr/bin/env\r" or similar).

*.sh        text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf
.env*       text eol=lf

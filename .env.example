# ============================================================
#  LLM PROVIDER CONFIG (provider-agnostic, OpenAI-compatible)
# ============================================================
# Switching providers is a config change, not a code change.
# llm-eval.mjs reads these four vars and routes to the right API.

LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_MAX_TOKENS=4096

# ---- Provider-specific keys (kept so you don't lose them when switching) ----
# Paste whichever one you're actively using into LLM_API_KEY above.
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ---- Provider preset reference (uncomment ONE block to switch) -------------
# OpenRouter (default — aggregator, dozens of models, ~$0.40-0.80/M tokens):
#   LLM_PROVIDER=openrouter
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#
# Groq (free tier 12k TPM on 70B, fast inference):
#   LLM_PROVIDER=groq
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# DeepInfra (cheapest direct provider for Llama 3.3 70B):
#   LLM_PROVIDER=deepinfra
#   LLM_BASE_URL=https://api.deepinfra.com/v1/openai
#   LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
#
# OpenAI (gpt-4o-mini, very cheap and reliable):
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini

# ============================================================
#  DISCORD
# ============================================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALERTS_CHANNEL_ID=
DISCORD_INPUT_CHANNEL_ID=
DISCORD_STATUS_CHANNEL_ID=
DISCORD_LOGS_CHANNEL_ID=

# Min score (out of 5) to post an individual eval to #job-alerts.
# Sub-threshold evals still get counted in the daily digest.
DISCORD_POST_THRESHOLD=4.0

# Hour-of-day (America/New_York, 24h) to post the daily digest to
# #pipeline-status. Bot checks every minute and posts once per ET day.
DIGEST_HOUR_ET=7

# ============================================================
#  DROPLET
# ============================================================
DROPLET_IP=

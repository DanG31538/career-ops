# Personal data (user fills these)
# NOTE (Dan's fork): cv.md is now tracked — it's part of the deployable config.
# Upstream career-ops keeps cv.md ignored because their repo is shared; ours is private.
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization
# NOTE (Dan's fork): config/profile.yml, portals.yml, modes/_profile.md are now
# tracked — they're part of the deployable config the droplet needs.
# Upstream career-ops keeps them ignored for multi-user reasons; we don't need that.
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json
.env
